SMOVIE_HOST=0.0.0.0
# Si http://127.0.0.1:8090 ne répond pas comme prévu, un autre programme peut occuper 8090 (ex. Wondershare) : utilise 8091.
SMOVIE_PORT=8091
SMOVIE_DEBUG=false
SMOVIE_COOKIE_SECURE=false
SMOVIE_TEMPLATE_RELOAD=false
SMOVIE_MAX_CONTENT_LENGTH=1048576
SMOVIE_SECRET_KEY=change-me-with-a-long-random-secret
SMOVIE_SESSION_COOKIE_NAME=smovie_session
TMDB_BEARER_TOKEN=your_tmdb_bearer_token_here
FANART_API_KEY=
SMOVIE_IMPORT_MAX_SEASONS=2
SMOVIE_IMPORT_MAX_EPISODES=12
