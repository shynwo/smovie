SMOVIE_HOST=0.0.0.0
# Si http://127.0.0.1:8090 ne répond pas comme prévu, un autre programme peut occuper 8090 (ex. Wondershare) : utilise 8091.
SMOVIE_PORT=8091
SMOVIE_DEBUG=false
# production | prod : cookies Secure par défaut, cache /library/ plus long, schéma https par défaut (surchargeable).
SMOVIE_ENV=development
SMOVIE_LOG_LEVEL=INFO
# Forcer explicitement (sinon : false en dev, true si SMOVIE_ENV=production).
SMOVIE_COOKIE_SECURE=false
# Pour url_for(..., _external=True) derrière reverse-proxy TLS.
SMOVIE_PREFERRED_URL_SCHEME=
# Cache-Control max-age secondes pour /library/ (défaut : 86400 dev, 604800 prod si non défini).
SMOVIE_LIBRARY_CACHE_MAX_AGE=
# En-tête HSTS uniquement si la requête est considérée HTTPS (ProxyFix + X-Forwarded-Proto).
SMOVIE_HSTS=max-age=31536000; includeSubDomains
SMOVIE_TEMPLATE_RELOAD=false
SMOVIE_MAX_CONTENT_LENGTH=1048576
SMOVIE_SECRET_KEY=change-me-with-a-long-random-secret
SMOVIE_SESSION_COOKIE_NAME=smovie_session
TMDB_BEARER_TOKEN=your_tmdb_bearer_token_here
FANART_API_KEY=
SMOVIE_IMPORT_MAX_SEASONS=2
SMOVIE_IMPORT_MAX_EPISODES=12
# Base URL du lecteur Next (sans slash final). Les boutons « Regarder » ouvrent cette app.
# Exemple : http://127.0.0.1:3000 — lancer : npm run player:dev
SMOVIE_PLAYER_BASE=http://127.0.0.1:3000
