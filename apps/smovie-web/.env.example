# Origine du backend Flask (catalogue + /media/… + /tmp-media/…)
SMOVIE_FLASK_ORIGIN=http://127.0.0.1:8091

# Fichier vidéo dans le dossier tmp/ à la racine du dépôt (route Flask /tmp-media/…)
# Exemple : place test.mp4 dans tmp/ puis :
SMOVIE_TMP_TEST_FILE=test.mp4

# URL de secours si le média n’a pas library_path / source_path (démo par défaut intégrée)
# SMOVIE_DEMO_VIDEO_URL=https://example.com/video.mp4

# Mettre 1 pour lire d’abord http://FLASK/media/smovie-test.mp4 (dépose le fichier sous media/)
# SMOVIE_PREFER_LOCAL_MEDIA=1
# SMOVIE_LOCAL_TEST_MP4=smovie-test.mp4
